{
  "name": "freeside-integrations",
  "version": "0.1.0",
  "private": true,
  "description": "Freeside integrations building: evidence-backed provider ingress plus preserved medium capability and rendering packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-mediums.git"
  },
  "workspaces": [
    "packages/protocol",
    "packages/cli-renderer",
    "packages/discord-renderer",
    "packages/integrations-core"
  ],
  "scripts": {
    "prepare": "./scripts/prepare-effect.sh",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test packages",
    "beacon:verify": "bun test packages/protocol/tests/beacon.test.ts",
    "acvp:verify": "bun scripts/acvp-verify.ts",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
